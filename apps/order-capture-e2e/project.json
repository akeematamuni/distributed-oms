{
    "name": "order-capture-e2e",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "implicitDependencies": ["order-capture"],
    "targets": {
        "e2e": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
            "options": {
                "jestConfig": "apps/order-capture-e2e/jest.config.cts",
                "passWithNoTests": true
            },
            "dependsOn": ["order-capture:build", "order-capture:serve"]
        }
    }
}
